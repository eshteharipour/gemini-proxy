# =============================================================================
# Gemini → OpenAI Proxy  —  shared .env.example  (works for v1 and v2)
# Copy to .env and fill in your real values.
# =============================================================================

# For file upload
GENERAL_PROXY=http://user:pass@proxy.internal:8080

# ── API Keys & Proxy Pairing ──────────────────────────────────────────────────
#
# RECOMMENDED — Style 1: explicit indexed pairs
# Each key is permanently bound to one proxy.
# Omit GEMINI_PROXY_N to use a direct (no-proxy) connection for that key.
#
GEMINI_KEY_0=AIzaSyAAAAAAAAAAAAAAAAAAAA0
GEMINI_PROXY_0=http://user:pass@proxy0.internal:8080

GEMINI_KEY_1=AIzaSyAAAAAAAAAAAAAAAAAAAA1
GEMINI_PROXY_1=http://user:pass@proxy1.internal:8080

GEMINI_KEY_2=AIzaSyAAAAAAAAAAAAAAAAAAAA2
# No proxy for key 2 — direct connection


# ALTERNATIVE — Style 2: single CSV  (key|proxy pairs, proxy optional)
# Uncomment and remove the Style 1 vars above if you prefer this.
#
# GEMINI_PAIRS_CSV=AIzaSyKey1|http://proxy1:8080,AIzaSyKey2|http://proxy2:8080,AIzaSyKey3


# LEGACY — Style 3: separate key + proxy CSVs  (keys round-robin over proxies)
# Kept for backwards compatibility with the original GeminiOpenAI class.
#
# GEMINI_API_CSV=AIzaSyKey1,AIzaSyKey2,AIzaSyKey3
# PROXY_CSV=http://proxy1:8080,http://proxy2:8080


# ── Model ─────────────────────────────────────────────────────────────────────
#
DEFAULT_GEMINI_MODEL=gemini-flash-lite-latest

# Model used by the integration test suite (should be fast and cheap)
TEST_GEMINI_MODEL=gemini-flash-lite-latest


# ── Retry / Cooldown behaviour ────────────────────────────────────────────────
#
# How long (seconds) a key is benched after a 429 / 503
KEY_COOLDOWN_SECONDS=60

# How long to sleep before rechecking when ALL keys are exhausted
ALL_EXHAUSTED_SLEEP_SECONDS=5

# Max Gemini call attempts per incoming request before returning 502
MAX_RETRIES=5


# ── Debug mode ────────────────────────────────────────────────────────────────
#
# Set to 1 to enable:
#   - DEBUG-level logging to stderr AND to a file
#   - every Gemini request + response written as JSONL to DEBUG_LOG_FILE
#   - base64 image payloads are truncated so the file stays readable
#
DEBUG_MODE=0
DEBUG_LOG_FILE=gemini_proxy_debug.log


# ── Server ────────────────────────────────────────────────────────────────────
#
HOST=0.0.0.0
PORT=8000
