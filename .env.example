# ── Key ↔ Proxy pairs (recommended) ──────────────────────────────────────────
# Each key is pinned to exactly one proxy.

# Style 1: indexed env vars (most explicit)
GEMINI_KEY_0=AIzaSyAAAAAAAAAAAAAAAAAAAA0
GEMINI_PROXY_0=http://user:pass@proxy0.internal:8080

GEMINI_KEY_1=AIzaSyAAAAAAAAAAAAAAAAAAAA1
GEMINI_PROXY_1=http://user:pass@proxy1.internal:8080

GEMINI_KEY_2=AIzaSyAAAAAAAAAAAAAAAAAAAA2
# No GEMINI_PROXY_2 → this key uses no proxy (direct connection)

# Style 2: single CSV (alternative)
# GEMINI_PAIRS_CSV=key1|http://proxy1:8080,key2|http://proxy2:8080,key3

# Style 3: legacy (keys round-robin over proxies)
# GEMINI_API_CSV=key1,key2,key3
# PROXY_CSV=http://proxy1:8080,http://proxy2:8080

# ── Tuning ────────────────────────────────────────────────────────────────────
KEY_COOLDOWN_SECONDS=60          # how long a 429'd key sits out
ALL_EXHAUSTED_SLEEP_SECONDS=5    # sleep when every key is on cooldown
MAX_RETRIES=5                    # attempts per request before giving up
DEFAULT_GEMINI_MODEL=gemini-2.0-flash

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
